generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String       @id @default(cuid())
  callsign           String
  name               String
  email              String       @unique
  passwordHash       String
  role               String       @default("MEMBER")
  collegeSlug        String?
  createdAt          DateTime     @default(now())
  checkIns           CheckIn[]    @relation("CheckInSubject")
  createdCheckIns    CheckIn[]    @relation("CheckInCreator")
  controlledSessions NetSession[] @relation("ControlOp")
  suggestions        TopicSuggestion[] @relation("TopicCreator")
  messages           SessionMessage[] @relation("MessageAuthor")

  @@index([callsign])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TopicSuggestion {
  id          String   @id @default(cuid())
  title       String
  details     String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("TopicCreator", fields: [createdById], references: [id], onDelete: Cascade)
  sessions    NetSession[] @relation("SessionTopic")
}

model Repeater {
  id         String   @id @default(cuid())
  name       String
  frequency  Float
  offsetKhz  Int
  toneHz     Float?
  mode       String
  coverage   String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  nets       Net[]
  netLinks   NetLink[] @relation("LinkedNet")
}

model Net {
  id         String       @id @default(cuid())
  name       String
  repeaterId String
  repeater   Repeater     @relation(fields: [repeaterId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startLocal String
  timezone   String
  theme      String?
  scriptMd   String?
  active     Boolean      @default(true)
  sessions   NetSession[]
  links      NetLink[]
}

model NetLink {
  id         String   @id @default(cuid())
  netId      String
  net        Net      @relation(fields: [netId], references: [id], onDelete: Cascade)
  repeaterId String
  repeater   Repeater @relation("LinkedNet", fields: [repeaterId], references: [id], onDelete: Cascade)
  note       String?
  createdAt  DateTime @default(now())

  @@unique([netId, repeaterId])
  @@index([netId])
}

model NetSession {
  id          String    @id @default(cuid())
  netId       String
  net         Net       @relation(fields: [netId], references: [id], onDelete: Cascade)
  startedAt   DateTime
  endedAt     DateTime?
  controlOpId String?
  controlOp   User?     @relation("ControlOp", fields: [controlOpId], references: [id], onDelete: SetNull)
  notes       String?
  topicId     String?
  topic       TopicSuggestion? @relation("SessionTopic", fields: [topicId], references: [id], onDelete: SetNull)
  topicTitle  String?
  checkIns    CheckIn[]
  messages    SessionMessage[]

  @@index([startedAt])
}

model SessionMessage {
  id            String     @id @default(cuid())
  sessionId     String
  session       NetSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?      @relation("MessageAuthor", fields: [userId], references: [id], onDelete: SetNull)
  callsign      String
  nameAtMessage String
  body          String
  createdAt     DateTime   @default(now())

  @@index([sessionId, createdAt])
  @@index([userId])
}

model CheckIn {
  id            String     @id @default(cuid())
  sessionId     String
  session       NetSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?      @relation("CheckInSubject", fields: [userId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?      @relation("CheckInCreator", fields: [createdById], references: [id], onDelete: SetNull)
  callsign      String
  nameAtCheckIn String
  checkedInAt   DateTime   @default(now())
  comment       String?

  @@index([sessionId])
  @@index([callsign])
  @@index([checkedInAt])
}
