generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String       @id @default(cuid())
  callsign           String       @unique
  name               String
  email              String       @unique
  passwordHash       String
  role               String       @default("MEMBER")
  collegeSlug        String?
  createdAt          DateTime     @default(now())
  checkIns           CheckIn[]    @relation("CheckInSubject")
  createdCheckIns    CheckIn[]    @relation("CheckInCreator")
  controlledSessions NetSession[] @relation("ControlOp")
}

model Repeater {
  id         String   @id @default(cuid())
  name       String
  frequency  Float
  offsetKhz  Int
  toneHz     Float?
  mode       String
  coverage   String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  nets       Net[]
}

model Net {
  id         String       @id @default(cuid())
  name       String
  repeaterId String
  repeater   Repeater     @relation(fields: [repeaterId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startLocal String
  timezone   String
  theme      String?
  scriptMd   String?
  active     Boolean      @default(true)
  sessions   NetSession[]
}

model NetSession {
  id          String    @id @default(cuid())
  netId       String
  net         Net       @relation(fields: [netId], references: [id], onDelete: Cascade)
  startedAt   DateTime
  endedAt     DateTime?
  controlOpId String?
  controlOp   User?     @relation("ControlOp", fields: [controlOpId], references: [id], onDelete: SetNull)
  notes       String?
  checkIns    CheckIn[]

  @@index([startedAt])
}

model CheckIn {
  id            String     @id @default(cuid())
  sessionId     String
  session       NetSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?      @relation("CheckInSubject", fields: [userId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?      @relation("CheckInCreator", fields: [createdById], references: [id], onDelete: SetNull)
  callsign      String
  nameAtCheckIn String
  checkedInAt   DateTime   @default(now())
  comment       String?

  @@index([sessionId])
  @@index([callsign])
  @@index([checkedInAt])
}
